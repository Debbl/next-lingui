{
  "name": "next-lingui",
  "type": "module",
  "version": "0.0.0",
  "author": "Brendan Dash <me@aiwan.run> (https://aiwan.run)",
  "license": "MIT",
  "homepage": "https://github.com/Debbl/next-lingui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Debbl/next-lingui.git"
  },
  "typings": "./dist/index.react-client.d.mts",
  "keywords": [
    "react",
    "intl",
    "i18n",
    "internationalization",
    "localization",
    "translate",
    "translation",
    "format",
    "formatting",
    "next",
    "next.js"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.react-client.d.mts",
      "react-server": "./dist/index.react-server.mjs",
      "default": "./dist/index.react-client.mjs"
    },
    "./server": {
      "types": "./dist/server.react-server.d.mts",
      "react-server": "./dist/server.react-server.mjs",
      "default": "./dist/server.react-client.mjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.mts",
      "default": "./dist/middleware.mjs"
    },
    "./navigation": {
      "types": "./dist/navigation.react-client.d.mts",
      "react-server": "./dist/navigation.react-server.mjs",
      "default": "./dist/navigation.react-client.mjs"
    },
    "./routing": {
      "types": "./dist/routing.d.mts",
      "default": "./dist/routing.mjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.mts",
      "default": "./dist/plugin.mjs"
    },
    "./_internal/request-config": {
      "types": "./_internal/request-config.d.mts",
      "default": "./_internal/request-config.mjs"
    }
  },
  "main": "./dist/index.react-client.mjs",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "verify:build-output": "node ./scripts/verify-build-output.mjs",
    "build:verify": "pnpm run build && pnpm run lint:package && pnpm run verify:build-output",
    "test": "vitest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@lingui/core": "^5.9.2",
    "@lingui/react": "^5.9.2",
    "next": "^12.0.0 || ^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || >=19.0.0-rc <19.0.0 || ^19.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.5.10",
    "negotiator": "^1.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@edge-runtime/vm": "^5.0.0",
    "@lingui/core": "^5.9.2",
    "@lingui/react": "^5.9.2",
    "@testing-library/react": "^16.3.2",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack": "^5.28.5",
    "eslint": "^9.39.3",
    "eslint-config-molindo": "^8.0.0",
    "eslint-plugin-react-compiler": "0.0.0-experimental-8e3b87c-20240822",
    "next": "^16.1.6",
    "path-to-regexp": "^6.3.0",
    "prettier": "^3.8.1",
    "publint": "^0.2.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.16.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
