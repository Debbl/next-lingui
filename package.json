{
  "name": "next-lingui-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "description": "Next.js + Lingui",
  "author": "Brendan Dash <me@aiwan.run> (https://aiwan.run)",
  "license": "MIT",
  "homepage": "https://github.com/Debbl/next-lingui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Debbl/next-lingui.git"
  },
  "bugs": "https://github.com/Debbl/next-lingui/issues",
  "keywords": [],
  "scripts": {
    "build": "pnpm --filter next-lingui build",
    "test": "vitest",
    "release": "pnpm build && bumpp -r",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@debbl/eslint-config": "^3.15.2",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.3",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "vitest": "3.0.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "echo 'lint-staged is disabled'"
  }
}
